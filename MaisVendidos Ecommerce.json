    {
      "parameters": {
        "jsCode": "// ============================================================\n// Amazon Best Sellers — Extrator Avançado (v2.0)\n// n8n Code Node | Melhora: Departamentos, Rankings e Imagens\n// ============================================================\n\nconst html = items[0].json.data;\n\nif (!html) {\n  throw new Error('Nenhum HTML recebido. Verifique o nó anterior.');\n}\n\nconst products = [];\n\n/**\n * 1. Divide o HTML em blocos por categoria.\n * Procura pelo cabeçalho \"Mais Vendidos em [NOME]\" e pega o conteúdo até a próxima seção.\n */\nconst sectionRegex = /<h2[^>]*class=\"[^\"]*a-carousel-heading[^\"]*\"[^>]*>Mais Vendidos em ([^<]+)<\\/h2>([\\s\\S]*?)(?=<h2[^>]*class=\"[^\"]*a-carousel-heading|$)/g;\n\nlet sectionMatch;\nwhile ((sectionMatch = sectionRegex.exec(html)) !== null) {\n  const categoryName = sectionMatch[1].trim();\n  const sectionHtml = sectionMatch[2];\n\n  /**\n   * 2. Extrai os cards de produtos dentro desta seção específica.\n   * Regex atualizado para incluir a captura da imagem (src).\n   */\n  const cardRegex = /data-asin=\"([^\"]+)\"[\\s\\S]*?zg-bdg-text[^>]*>#(\\d+)<\\/span[\\s\\S]*?<img[^>]*src=\"([^\"]+)\"[\\s\\S]*?p13n-sc-line-clamp[^>]*>([\\s\\S]*?)<\\/div[\\s\\S]*?p13n-sc-price[^>]*>([\\s\\S]*?)<\\/span/g;\n\n  let cardMatch;\n  while ((cardMatch = cardRegex.exec(sectionHtml)) !== null) {\n    const asin     = cardMatch[1];\n    const ranking  = parseInt(cardMatch[2], 10);\n    const imageUrl = cardMatch[3];\n    const rawName  = cardMatch[4];\n    const rawPrice = cardMatch[5];\n\n    // Limpeza de Nome\n    const name = rawName\n      .replace(/<[^>]+>/g, '')\n      .replace(/\\s+/g, ' ')\n      .trim();\n\n    // Limpeza e normalização do preço (Mantendo sua lógica original)\n    const priceStr = rawPrice.replace(/<[^>]+>/g, '').trim();\n    const priceNum = parseFloat(\n      priceStr\n        .replace(/R\\$\\s*/g, '')\n        .replace(/\\./g, '')\n        .replace(/,/g, '.')\n    ) || null;\n\n    const url = `https://www.amazon.com.br/dp/${asin}`;\n\n    // Adiciona o produto garantindo que o ranking está atrelado a esta categoria\n    products.push({\n      ranking,\n      category: categoryName,\n      name,\n      price: priceNum,\n      price_raw: priceStr,\n      image: imageUrl,\n      asin,\n      url,\n      scraped_at: new Date().toISOString()\n    });\n  }\n}\n\n// 3. Ordenação final para garantir organização no n8n\nproducts.sort((a, b) => a.category.localeCompare(b.category) || a.ranking - b.ranking);\n\n// 4. Retorna como itens individuais\nreturn products.map(p => ({ json: p }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
