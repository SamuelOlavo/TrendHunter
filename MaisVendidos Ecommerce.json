      "parameters": {
        "jsCode": "const data = items[0].json.data;\nconst secoesMap = {}; // Balde para agrupar produtos por seção\n\nconst regexTitulo = /\"title\":\"(.*?)\"/g;\nlet match;\n\nwhile ((match = regexTitulo.exec(data)) !== null) {\n    const titulo = match[1];\n    const inicio = Math.max(0, match.index - 500);\n    const fim = Math.min(data.length, match.index + 1200);\n    const pedacoTexto = data.substring(inicio, fim);\n\n    const matchLink = pedacoTexto.match(/\"permalink\":\"(.*?)\"/);\n    if (!matchLink) continue;\n\n    const linkFinal = matchLink[1].replace(/\\\\u002F/g, '/');\n\n    // FILTRO: Ignora links de menus e listas de \"mais-vendidos\" (os que geram o \"Geral\")\n    if (linkFinal.includes('/mais-vendidos/') || titulo.includes(\"Preferências de cookies\")) continue;\n\n    // Identifica a Seção via campanha\n    let secaoIdentificada = \"\";\n    const matchCampanha = linkFinal.match(/c_campaign=([^&]+)/);\n    \n    if (matchCampanha) {\n        secaoIdentificada = matchCampanha[1].replace(/-/g, ' ');\n        secaoIdentificada = secaoIdentificada.charAt(0).toUpperCase() + secaoIdentificada.slice(1);\n    } else {\n        // Se não tem campanha no link, provavelmente é um link institucional ou menu\n        continue; \n    }\n\n    if (!secoesMap[secaoIdentificada]) {\n        secoesMap[secaoIdentificada] = [];\n    }\n\n    // Limite de 10 por seção\n    if (secoesMap[secaoIdentificada].length >= 10) continue;\n\n    const matchPreco = pedacoTexto.match(/\"price\":([\\d.]+)/);\n    const matchFoto = pedacoTexto.match(/\"thumbnail\":\"(.*?)\"/);\n    \n    let precoFormatado = matchPreco ? \n        parseFloat(matchPreco[1]).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) : \n        \"Sob consulta\";\n        \n    const fotoFinal = matchFoto ? matchFoto[1].replace(/\\\\u002F/g, '/') : \"Sem foto\";\n\n    secoesMap[secaoIdentificada].push({\n        secao: secaoIdentificada,\n        produto: titulo,\n        preco: precoFormatado,\n        foto: fotoFinal,\n        link: linkFinal\n    });\n}\n\n// ORGANIZAÇÃO FINAL\nconst resultadosFinais = [];\n// Corrigido de 'em' para 'in'\nfor (const secao in secoesMap) {\n    secoesMap[secao].forEach((item, index) => {\n        resultadosFinais.push({\n            json: {\n                ranking_na_secao: index + 1,\n                ...item\n            }\n        });\n    });\n}\n\nreturn resultadosFinais;"
      },
