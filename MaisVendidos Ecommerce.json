        "message": "=<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: auto; background-color: #ffffff; border: 1px solid #eee;\">\n  \n  <div style=\"background-color: #000; padding: 15px; text-align: center;\">\n    <h1 style=\"color: #d4ff3f; margin: 0; font-size: 22px; letter-spacing: 1px;\">TRENDHUNTER</h1>\n  </div>\n\n<div style=\"font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; max-width: 600px; margin: auto; background-color: #f4f7f6; padding: 20px; border-radius: 15px;\">\n\n  \n\n  <div style=\"text-align: center; padding-bottom: 20px;\">\n\n    <h2 style=\"color: #1a1a1a; margin-bottom: 5px;\">🚀 Relatório Diário</h2>\n\n    <p style=\"color: #666; font-size: 14px;\">As melhores oportunidades encontradas em {{ $json.data[0].data }}</p>\n\n  </div>\n\n\n\n  {{ $json.data.map(item => `\n\n    <table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"background-color: white; border: 1px solid #e0e0e0; border-radius: 12px; margin-bottom: 15px; overflow: hidden;\">\n\n      <tr>\n\n        <td width=\"120\" style=\"padding: 15px; text-align: center; background-color: #fff;\">\n\n          <img src=\"${item.image_url}\" width=\"100\" style=\"border-radius: 5px; display: block; margin: auto; object-fit: contain;\">\n\n        </td>\n\n        \n\n        <td style=\"padding: 15px; vertical-align: top;\">\n\n          <div style=\"background: ${item.platform === 'Amazon' ? '#ff9900' : '#ffe600'}; color: #000; display: inline-block; padding: 3px 10px; border-radius: 20px; font-weight: bold; font-size: 10px; text-transform: uppercase;\">\n\n            ${item.platform} | #${item.ranking} no Ranking\n\n          </div>\n\n          \n\n          <strong style=\"font-size: 15px; color: #2c3e50; display: block; margin: 10px 0 5px 0; line-height: 1.4;\">\n\n            ${item.name.replace(/&#x27;/g, \"'\")}\n\n          </strong>\n\n          \n\n          <span style=\"color: #95a5a6; font-size: 12px; display: block; margin-bottom: 15px;\">Categoria: ${item.category}</span>\n\n          \n\n          <table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n\n            <tr>\n\n              <td>\n\n                <span style=\"color: #27ae60; font-weight: bold; font-size: 20px;\">\n\n                  R$ ${item.price_current.toLocaleString('pt-BR', {minimumFractionDigits: 2})}\n\n                </span>\n\n              </td>\n\n              <td align=\"right\">\n\n                <a href=\"${item.url}\" style=\"background-color: #2980b9; color: white; text-decoration: none; padding: 8px 18px; border-radius: 8px; font-size: 13px; font-weight: bold; display: inline-block;\">\n\n                  Ver Oferta\n\n                </a>\n\n              </td>\n\n            </tr>\n\n          </table>\n\n        </td>\n\n      </tr>\n\n    </table>\n\n  `).join('') }}\n\n\n\n  <div style=\"text-align: center; color: #95a5a6; font-size: 11px;\">\n<p>Monitoramento automático via <strong>Trend Hunter</strong></p>\n   \n  </div>\n</div>\n <div style=\"background-color: #000; padding: 15px; text-align: center;\">\n    <a href=\"URL_DA_SUA_PLATAFORMA_AQUI\" style=\"background-color: #d4ff3f; color: #000; text-decoration: none; padding: 10px 25px; border-radius: 5px; font-weight: bold; font-size: 14px; display: inline-block; border: 1px solid #000;\">\n      💻 ACESSAR PLATAFORMA COMPLETA\n    </a>\n</div>\n",
