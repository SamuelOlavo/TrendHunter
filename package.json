  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.4",
    "autoprefixer": "^10.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.0",
    "ws": "^8.20.1"
